{
  "rules": [
    {
      "rule_id": "PD009",
      "rule_name": "OpenAI API Key",
      "pattern": "sk-[a-zA-Z0-9]{20,}",
      "level": "critical",
      "action": "mask",
      "mask_char": "*",
      "mask_keep": 4,
      "test_cases": {
        "positive": ["sk-proj-abc123def456ghi789", "sk-1234567890abcdefghijklmnop"],
        "negative": ["API Key", "sk-", "密钥"]
      }
    },
    {
      "rule_id": "PD010",
      "rule_name": "AWS Access Key",
      "pattern": "AKIA[A-Z0-9]{16}",
      "level": "critical",
      "action": "mask",
      "mask_char": "*",
      "mask_keep": 4,
      "test_cases": {
        "positive": ["AKIAIOSFODNN7EXAMPLE", "AKIA1234567890ABCDEF"],
        "negative": ["AWS_KEY", "AKIA", "Access Key"]
      }
    },
    {
      "rule_id": "PD011",
      "rule_name": "GitHub Token",
      "pattern": "ghp_[a-zA-Z0-9]{36}",
      "level": "critical",
      "action": "mask",
      "mask_char": "*",
      "mask_keep": 4,
      "test_cases": {
        "positive": ["ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"],
        "negative": ["github_token", "ghp_", "GitHub Token"]
      }
    },
    {
      "rule_id": "PD012",
      "rule_name": "JWT Token",
      "pattern": "eyJ[a-zA-Z0-9_-]*\\.eyJ[a-zA-Z0-9_-]*\\.[a-zA-Z0-9_-]*",
      "level": "critical",
      "action": "mask",
      "mask_char": "*",
      "mask_keep": 0,
      "test_cases": {
        "positive": ["eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWI6OiIxMjM0NTY3ODkwIn0.signature"],
        "negative": ["jwt_token", "token", "JWT"]
      }
    },
    {
      "rule_id": "PD013",
      "rule_name": "密码模式",
      "pattern": "(password|passwd|pwd|密码|口令)[:=]\\s*[\"']?[a-zA-Z0-9!@#$%^&*()_+=-]{8,}[\"']?",
      "level": "critical",
      "action": "mask",
      "mask_char": "*",
      "mask_keep": 0,
      "test_cases": {
        "positive": ["password=MySecret123!", "passwd: admin12345", "密码：test123456"],
        "negative": ["password field", "密码字段", "输入密码"]
      }
    },
    {
      "rule_id": "PD014",
      "rule_name": "私钥内容",
      "pattern": "-----BEGIN (RSA |DSA |EC |OPENSSH )?PRIVATE KEY-----",
      "level": "critical",
      "action": "mask",
      "mask_char": "*",
      "mask_keep": 0,
      "test_cases": {
        "positive": ["-----BEGIN RSA PRIVATE KEY-----", "-----BEGIN PRIVATE KEY-----"],
        "negative": ["private_key", "私钥", "密钥文件"]
      }
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "category": "privacy",
    "subcategory": "credentials",
    "description": "国际开发凭证类隐私正则规则（API Key、Token、密码等）",
    "total_rules": 6,
    "total_patterns": 6,
    "coverage": ["OpenAI Key", "AWS Key", "GitHub Token", "JWT", "密码", "私钥"],
    "created_at": "2026-04-14",
    "note": "中国开发者常用凭证，必须包含"
  }
}